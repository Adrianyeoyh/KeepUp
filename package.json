{
  "name": "flowguard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend/gateway",
    "backend/publishers/*",
    "backend/consumers/*",
    "backend/packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:frontend": "npm run dev --workspace=@flowguard/frontend",
    "dev:gateway": "npm run dev --workspace=@flowguard/gateway",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "npm run migrate --workspace=@flowguard/db",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "admin:bootstrap": "bash scripts/bootstrap-admin.sh",
    "tunnel": "bash scripts/tunnel-dev.sh",
    "seed:dev": "npx tsx scripts/seed-dev.ts",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  }
}
