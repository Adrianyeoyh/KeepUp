# ============================================
# FlowGuard — Environment Variables
# ============================================
# Copy this to .env and fill in your values

# ---- Database (Postgres) ----
DATABASE_URL=postgresql://flowguard:flowguard@localhost:5432/flowguard

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- API Server ----
API_PORT=3001
NODE_ENV=development
ADMIN_API_KEY=

# ---- Slack ----
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ---- Jira ----
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_WEBHOOK_SECRET=

# ---- GitHub ----
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# ---- LLM (AI Orchestrator) ----
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o

# ---- FlowGuard Config ----
INSIGHT_BUDGET_PER_DAY=3
CONFIDENCE_THRESHOLD=0.5
DIGEST_CRON=0 9 * * 1-5
DEFAULT_COMPANY_SLUG=flowguard-default
DEFAULT_COMPANY_NAME=FlowGuard Default Company

# ---- Dev Tunnel (auto-updates webhook URLs) ----
# Get a Slack App Configuration Token at: https://api.slack.com/apps → Your App → "App Configuration Tokens"
SLACK_APP_CONFIG_TOKEN=
SLACK_APP_ID=
# GitHub App private key path (for JWT generation to update webhook URL)
GITHUB_APP_PEM_PATH=
# Jira webhook auto-registration
JIRA_USER_EMAIL=
JIRA_WEBHOOK_NAME=FlowGuard Dev

# ---- Admin Bootstrap Script (optional) ----
API_BASE_URL=http://localhost:3001
COMPANY_ID=
DIGEST_USER_IDS=
DIGEST_CHANNEL_IDS=

SLACK_STATUS=active
SLACK_TEAM_ID=
SLACK_TEAM_NAME=
SLACK_BOT_USER_ID=
SLACK_SCOPES=

JIRA_STATUS=active
JIRA_BASE_URL=
JIRA_ACCESS_TOKEN=
JIRA_CLOUD_ID=
JIRA_PROJECT_KEYS=
JIRA_SCOPES=

GITHUB_STATUS=active
GITHUB_ACCESS_TOKEN=
GITHUB_REPO_FULL_NAME=
GITHUB_REPOSITORIES=
GITHUB_SCOPES=
